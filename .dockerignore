# Build output — never needed in the Docker build context
target/

# Version control
.git/
.gitignore

# IDE files
.idea/
*.iml
*.iws
*.ipr
.vscode/
.eclipse/

# OS metadata
.DS_Store
Thumbs.db

# Secrets — never send to Docker daemon
.env

# Maven wrapper jar (downloaded at build time inside the container)
.mvn/wrapper/maven-wrapper.jar

# Logs
*.log

# Documentation and reports — not needed to build the jar
README.md
postman/
specs/
report/
