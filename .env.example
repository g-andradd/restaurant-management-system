# ─────────────────────────────────────────────────────────────────────────────
# Tech Challenge — User Management API  ·  Environment variables
#
# Usage:
#   cp .env.example .env
#   Edit .env and replace JWT_SECRET with a real random value:
#     export JWT_SECRET=$(openssl rand -base64 48)
#
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Spring profile activated inside the container.
# Options: dev (H2 in-memory) | hom (PostgreSQL) | prod (PostgreSQL, no Swagger)
SPRING_PROFILES_ACTIVE=hom

# PostgreSQL connection — must match the db service in docker-compose.yml
DB_URL=jdbc:postgresql://db:5432/techchallenge
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT signing secret — HS256, minimum 32 bytes.
# This placeholder is ≥ 32 bytes and can be used as-is for a first run,
# but MUST be replaced with a random value for any real deployment.
# Generate a secure value with: openssl rand -base64 48
JWT_SECRET=RlF1w4QAo9GCW4kux7KlzyTiTsl0euvAsXnej1HS18d1T/CLmBW0n/fsx330WQk2

# Token time-to-live in seconds (default: 3600 = 1 hour).
JWT_EXPIRATION_SECONDS=3600
