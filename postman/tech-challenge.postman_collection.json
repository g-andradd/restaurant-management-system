    {
      "name": "2 — Update user data",
      "description": "Protected requests — inherit the collection-level Bearer token captured in Folder 0.",
      "item": [
        {
          "name": "Update existing user",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"name\": \"Tech Admin Updated\",\n  \"email\": \"admin@techchallenge.com\",\n  \"login\": \"techadmin\",\n  \"address\": {\n    \"street\": \"Rua Augusta\",\n    \"number\": \"500\",\n    \"city\": \"São Paulo\",\n    \"zipCode\": \"01305-100\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{adminId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{adminId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"name updated\", () => pm.expect(json.name).to.equal(\"Tech Admin Updated\"));",
                  "pm.test(\"updatedAt present\", () => pm.expect(json.updatedAt).to.be.a(\"string\"));",
                  "const createdAt = new Date(pm.environment.get(\"adminCreatedAt\"));",
                  "const updatedAt = new Date(json.updatedAt);",
                  "pm.test(\"updatedAt >= createdAt\", () => pm.expect(updatedAt.getTime()).to.be.at.least(createdAt.getTime()));"
                ]
              }
            }
          ]
