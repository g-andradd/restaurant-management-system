{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Tech Challenge — User Management API",
    "description": "Covers all acceptance criteria for FIAP Tech Challenge Phase 1 (M01–M10).\nRun folders in order on a fresh database. Folder 0 must run first to seed the admin and capture the JWT token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
