    {
      "name": "6 — Authorization edge cases",
      "description": "Validates JWT filter behavior. All three requests use auth:noauth so the collection-level Bearer token is NOT injected. Auth headers (or their absence) are set explicitly on each request.",
      "item": [
        {
          "name": "Protected — no Authorization header",
          "description": "No Authorization header at all. The filter skips (nothing to parse) and the entry point fires with 401.",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{adminId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{adminId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status 401\", () => pm.response.to.have.status(401));",
                  "const json = pm.response.json();",
                  "pm.test(\"unauthorized type\", () => pm.expect(json.type).to.include(\"/errors/unauthorized\"));",
                  "pm.test(\"status field 401\", () => pm.expect(json.status).to.equal(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "Protected — malformed token",
          "description": "Authorization header present but the token is not a valid JWT structure. parseToken() returns Optional.empty(), entry point fires with 401.",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer not.a.jwt.token"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/{{adminId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{adminId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
