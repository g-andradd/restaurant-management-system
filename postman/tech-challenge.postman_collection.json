            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"login\": \"ghostuser99\",\n  \"password\": \"WrongPass@1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status 401\", () => pm.response.to.have.status(401));",
                  "const json = pm.response.json();",
                  "pm.test(\"unauthorized type\", () => pm.expect(json.type).to.include(\"/errors/unauthorized\"));",
                  "pm.test(\"detail same as wrong-password\", () => pm.expect(json.detail).to.equal(\"Credenciais inválidas.\"));"
                ]
              }
            }
          ]
        }
      ]
