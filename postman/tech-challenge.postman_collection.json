                  "const json = pm.response.json();",
                  "pm.test(\"unauthorized type\", () => pm.expect(json.type).to.include(\"/errors/unauthorized\"));"
                ]
              }
            }
          ]
        },
        {
          "name": "Protected — wrong-signature token",
          "description": "Well-formed JWT (valid header+payload base64url) but signed with a DIFFERENT key than the server's JWT_SECRET. JJWT throws SignatureException, caught in JjwtTokenProviderAdapter.parseToken(), returns Optional.empty() → 401. This is the portable equivalent of an expired-token test: same filter path, no dependency on runtime JWT_SECRET.",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/{{adminId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{adminId}}"
              ]
            }
          },
          "event": [
