    {
      "name": "3 — Change password",
      "description": "Uses {{customerId}} set in Folder 1. Changes the customer's password then verifies login with the new credential.",
      "item": [
        {
          "name": "Change password — valid",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"newPassword\": \"NovaSenha@1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{customerId}}/password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{customerId}}",
                "password"
              ]
            }
