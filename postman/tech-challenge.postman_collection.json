  "item": [
    {
      "name": "0 — Auth setup",
      "description": "Seeds the admin user and captures the JWT token used by all subsequent protected requests. MUST run first.",
      "item": [
        {
          "name": "Register admin (seed)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"name\": \"Tech Admin\",\n  \"email\": \"admin@techchallenge.com\",\n  \"login\": \"techadmin\",\n  \"password\": \"Admin@1234\",\n  \"role\": \"ADMIN\",\n  \"address\": {\n    \"street\": \"Av. Paulista\",\n    \"number\": \"1000\",\n    \"city\": \"São Paulo\",\n    \"zipCode\": \"01310-100\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status 201\", () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test(\"id present\", () => pm.expect(json.id).to.be.a(\"string\"));",
                  "pm.test(\"no password in response\", () => pm.expect(json).to.not.have.property(\"password\"));",
                  "pm.test(\"no passwordHash in response\", () => pm.expect(json).to.not.have.property(\"passwordHash\"));",
                  "pm.environment.set(\"adminId\", json.id);",
                  "pm.environment.set(\"adminCreatedAt\", json.createdAt);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login admin",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"login\": \"techadmin\",\n  \"password\": \"Admin@1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status 200\", () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test(\"authenticated true\", () => pm.expect(json.authenticated).to.be.true);",
                  "pm.test(\"token present\", () => pm.expect(json.token).to.be.a(\"string\"));",
                  "pm.test(\"role present\", () => pm.expect(json.role).to.equal(\"ADMIN\"));",
                  "pm.test(\"expiresIn present\", () => pm.expect(json.expiresIn).to.be.a(\"number\"));",
                  "pm.environment.set(\"token\", json.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login admin — wrong password",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"login\": \"techadmin\",\n  \"password\": \"WrongPassword@1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status 401\", () => pm.response.to.have.status(401));",
                  "const json = pm.response.json();",
                  "pm.test(\"unauthorized type\", () => pm.expect(json.type).to.include(\"/errors/unauthorized\"));",
                  "pm.test(\"detail present\", () => pm.expect(json.detail).to.equal(\"Credenciais inválidas.\"));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login — unknown user",
          "description": "Non-existing login returns 401 with an identical body to wrong-password — the server does not reveal whether the user exists.",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
